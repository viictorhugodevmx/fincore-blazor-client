<span class="@BadgeClass">
    @Text
</span>

@code {
    [Parameter]
    public string Text { get; set; } = string.Empty;

    [Parameter]
    public string CssClass { get; set; } = "status-badge";

    private string NormalizedText =>
        Text
            .Trim()
            .ToLowerInvariant()
            .Replace(" ", "-");

    private string BadgeClass =>
        $"{CssClass} {NormalizedText}";
}
