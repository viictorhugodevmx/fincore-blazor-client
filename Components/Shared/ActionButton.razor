<button type="@Type" class="@CssClass" @onclick="OnClick">
    @Text
</button>

@code {
    [Parameter]
    public string Text { get; set; } = string.Empty;

    [Parameter]
    public string Type { get; set; } = "button";

    [Parameter]
    public string CssClass { get; set; } = "primary-button";

    [Parameter]
    public EventCallback OnClick { get; set; }
}
