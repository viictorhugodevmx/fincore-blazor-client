<section class="loading-state">
    <div class="loading-spinner"></div>

    <div>
        <h2>@Title</h2>
        <p>@Message</p>
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Cargando";

    [Parameter]
    public string Message { get; set; } = "Estamos preparando la información.";
}
