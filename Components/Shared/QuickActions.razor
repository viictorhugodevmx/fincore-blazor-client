@inject NavigationManager NavigationManager

<section class="quick-actions">
    <a class="@(IsActive("/accounts") ? "active" : "")" href="/accounts">
        Cuentas
    </a>

    <a class="@(IsActive("/transfers/new") ? "active" : "")" href="/transfers/new">
        Nueva transferencia
    </a>

    <a class="@(IsActive("/transfers/history") ? "active" : "")" href="/transfers/history">
        Historial
    </a>

    <a class="@(IsActive("/risk") ? "active" : "")" href="/risk">
        Riesgo
    </a>

    <a class="@(IsActive("/operations") ? "active" : "")" href="/operations">
        Operaciones
    </a>

    <a class="@(IsActive("/system-health") ? "active" : "")" href="/system-health">
        Salud sistema
    </a>
</section>

@code {
    private bool IsActive(string path)
    {
        var currentPath = new Uri(NavigationManager.Uri).AbsolutePath;

        return currentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
    }
}
