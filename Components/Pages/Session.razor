@page "/session"
@rendermode InteractiveServer
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@using FincoreBlazorClient.Components.Shared
@inject AuthSessionService AuthSessionService
@inject NavigationManager NavigationManager

<PageTitle>Sesión</PageTitle>

<PageHeader
    Eyebrow="Seguridad"
    Title="Sesión simulada"
    Description="Estado visual de autenticación usando un service en Blazor." />

@if (!SessionState.IsAuthenticated)
{
    <section class="session-card">
        <StatusBadge Text="No autenticado" CssClass="session-badge danger" />

        <h2>No hay sesión activa</h2>
        <p>Inicia sesión para simular acceso al portal bancario.</p>

        <ActionButton
            Text="Ir al login"
            OnClick="GoToLogin" />
    </section>
}
else
{
    <section class="session-card">
        <StatusBadge Text="Autenticado" CssClass="session-badge success" />

        <h2>@SessionState.Email</h2>
        <p>Sesión iniciada el @SessionState.LoggedAtUtc?.ToString("dd MMM yyyy HH:mm") UTC</p>

        <ActionButton
            Text="Cerrar sesión"
            CssClass="secondary-danger-button"
            OnClick="HandleLogout" />
    </section>
}

@code {
    private AuthSessionState SessionState { get; set; } = new();

    protected override void OnInitialized()
    {
        SessionState = AuthSessionService.GetSession();
    }

    private void GoToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }

    private void HandleLogout()
    {
        AuthSessionService.Logout();
        SessionState = AuthSessionService.GetSession();
    }
}
