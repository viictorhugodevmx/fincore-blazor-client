@page "/audit"
@rendermode InteractiveServer
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@inject DashboardService DashboardService

<PageTitle>Auditoría</PageTitle>

<section class="page-heading">
    <span class="eyebrow dark">Seguridad</span>
    <h1>Auditoría</h1>
    <p>Eventos simulados del portal con filtro por módulo.</p>
</section>

<section class="filter-card">
    <span>Filtrar por módulo</span>

    <div class="filter-actions">
        @foreach (var module in ModuleOptions)
        {
            <button
                type="button"
                class="filter-pill @(SelectedModule == module ? "active" : "")"
                @onclick="() => SelectModule(module)">
                @module
            </button>
        }
    </div>
</section>

<section class="audit-card">
    <div class="audit-timeline">
        @foreach (var auditEvent in FilteredAuditEvents)
        {
            <article class="audit-event">
                <div class="audit-dot @auditEvent.Result.ToLower()"></div>

                <div>
                    <span>@auditEvent.EventId · @auditEvent.Module</span>
                    <h2>@auditEvent.Action</h2>
                    <p>@auditEvent.Actor</p>
                    <small>@auditEvent.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</small>
                </div>

                <strong class="audit-result @auditEvent.Result.ToLower()">
                    @auditEvent.Result
                </strong>
            </article>
        }
    </div>
</section>

@code {
    private List<AuditEvent> AuditEvents { get; set; } = new();

    private List<string> ModuleOptions { get; set; } = new()
    {
        "All",
        "Auth",
        "Transfers",
        "Risk",
        "Security"
    };

    private string SelectedModule { get; set; } = "All";

    private IEnumerable<AuditEvent> FilteredAuditEvents =>
        SelectedModule == "All"
            ? AuditEvents
            : AuditEvents.Where(auditEvent =>
                auditEvent.Module.Equals(SelectedModule, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        AuditEvents = DashboardService.GetAuditEvents();
    }

    private void SelectModule(string module)
    {
        SelectedModule = module;
    }
}
