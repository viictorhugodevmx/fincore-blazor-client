@page "/system-health"
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@inject DashboardService DashboardService

<PageTitle>Salud del sistema</PageTitle>

<section class="page-heading">
    <span class="eyebrow dark">Operación técnica</span>
    <h1>Salud del sistema</h1>
    <p>Servicios simulados del portal para visualizar disponibilidad, latencia y estado operativo.</p>
</section>

<section class="health-grid">
    @foreach (var item in HealthItems)
    {
        <article class="health-card @item.Status.ToLower()">
            <div>
                <span class="health-status @item.Status.ToLower()">@item.Status</span>
                <h2>@item.ServiceName</h2>
                <p>@item.Detail</p>
            </div>

            <div class="health-meta">
                <strong>@item.LatencyMs ms</strong>
                <small>@item.CheckedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</small>
            </div>
        </article>
    }
</section>

@code {
    private List<SystemHealthItem> HealthItems { get; set; } = new();

    protected override void OnInitialized()
    {
        HealthItems = DashboardService.GetSystemHealth();
    }
}
