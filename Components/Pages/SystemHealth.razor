@page "/system-health"
@rendermode InteractiveServer
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@using FincoreBlazorClient.Components.Shared
@inject DashboardService DashboardService

<PageTitle>Salud del sistema</PageTitle>

<PageHeader
    Eyebrow="Operación técnica"
    Title="Salud del sistema"
    Description="Servicios simulados del portal con filtro por estado operativo." />

<BackofficeTabs />

<section class="filter-card">
    <span>Filtrar por estado</span>

    <div class="filter-actions">
        @foreach (var status in StatusOptions)
        {
            <button
                type="button"
                class="filter-pill @(SelectedStatus == status ? "active" : "")"
                @onclick="() => SelectStatus(status)">
                @status
            </button>
        }
    </div>
</section>

@if (!FilteredHealthItems.Any())
{
    <ModuleShell CssClass="health-grid">
        <EmptyState
            Eyebrow="Sin servicios"
            Title="No hay servicios"
            Message="No encontramos servicios para el estado seleccionado."
            ActionText="Ver todos"
            OnActionClick="ResetFilter" />
    </ModuleShell>
}
else
{
    <ModuleShell CssClass="health-grid">
        @foreach (var item in FilteredHealthItems)
        {
            <article class="health-card @item.Status.ToLower()">
                <div>
                    <span class="health-status @item.Status.ToLower()">@item.Status</span>
                    <h2>@item.ServiceName</h2>
                    <p>@item.Detail</p>
                </div>

                <div class="health-meta">
                    <strong>@item.LatencyMs ms</strong>
                    <small>@item.CheckedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</small>
                </div>
            </article>
        }
    </ModuleShell>
}

@code {
    private List<SystemHealthItem> HealthItems { get; set; } = new();

    private List<string> StatusOptions { get; set; } = new()
    {
        "All",
        "Healthy",
        "Degraded",
        "Offline",
        "Timeout demo"
    };

    private string SelectedStatus { get; set; } = "All";

    private IEnumerable<SystemHealthItem> FilteredHealthItems =>
        SelectedStatus == "All"
            ? HealthItems
            : HealthItems.Where(item =>
                item.Status.Equals(SelectedStatus, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        HealthItems = DashboardService.GetSystemHealth();
    }

    private void SelectStatus(string status)
    {
        SelectedStatus = status;
    }

    private void ResetFilter()
    {
        SelectedStatus = "All";
    }
}
