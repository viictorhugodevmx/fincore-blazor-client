@page "/not-found"
@using FincoreBlazorClient.Components.Shared

<PageTitle>Página no encontrada</PageTitle>

<section class="not-found-shell">
    <article class="not-found-card">
        <StatusBadge Text="404" CssClass="session-badge danger" />

        <h1>Página no encontrada</h1>
        <p>La ruta que intentaste abrir no existe dentro del portal bancario.</p>

        <div class="actions-row">
            <ActionLink Href="/" Text="Volver al dashboard" />

            <ActionLink
                Href="/operations"
                Text="Ver resumen operativo"
                CssClass="primary-link" />
        </div>
    </article>
</section>
