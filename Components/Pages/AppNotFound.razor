@page "/not-found"

<PageTitle>Página no encontrada</PageTitle>

<section class="not-found-shell">
    <article class="not-found-card">
        <span class="session-badge danger">404</span>
        <h1>Página no encontrada</h1>
        <p>La ruta que intentaste abrir no existe dentro del portal bancario.</p>

        <div class="actions-row">
            <a class="primary-button" href="/">
                Volver al dashboard
            </a>

            <a class="primary-link" href="/operations">
                Ver resumen operativo
            </a>
        </div>
    </article>
</section>
