@page "/"
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@inject DashboardService DashboardService

<PageTitle>FinCore Blazor Client</PageTitle>

<section class="hero">
    <div>
        <span class="eyebrow">FinCore Blazor Client</span>
        <h1>Dashboard financiero</h1>
        <p>
            Frontend Blazor para practicar componentes, estado y UI fintech usando C#.
        </p>
    </div>
</section>

<section class="metrics-grid">
    <article class="metric-card main-card">
        <span>Cliente</span>
        <h2>@Account.CustomerName</h2>
        <p>@Account.AccountNumber</p>
    </article>

    <article class="metric-card">
        <span>Saldo disponible</span>
        <h2>@Account.AvailableBalance.ToString("N2") @Account.Currency</h2>
        <p>Balance simulado</p>
    </article>

    <article class="metric-card">
        <span>Transferencias</span>
        <h2>@Account.PendingTransfers</h2>
        <p>Pendientes de revisión</p>
    </article>

    <article class="metric-card">
        <span>Riesgo</span>
        <h2>@Account.RiskLevel</h2>
        <p>Nivel operativo</p>
    </article>
</section>

<section class="movements-section">
    <div class="section-heading">
        <span class="eyebrow dark">Actividad reciente</span>
        <h2>Últimos movimientos</h2>
    </div>

    <div class="movement-list">
        @foreach (var movement in RecentMovements)
        {
            <article class="movement-row">
                <div>
                    <span class="movement-type">@movement.Type</span>
                    <h3>@movement.Description</h3>
                    <p>@movement.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</p>
                </div>

                <strong>@movement.Amount.ToString("N2") @movement.Currency</strong>
            </article>
        }
    </div>
</section>

@code {
    private DashboardAccount Account { get; set; } = new();
    private List<RecentMovement> RecentMovements { get; set; } = new();

    protected override void OnInitialized()
    {
        Account = DashboardService.GetDashboardAccount();
        RecentMovements = DashboardService.GetRecentMovements();
    }
}
