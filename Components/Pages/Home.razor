@page "/"
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@using FincoreBlazorClient.Components.Shared
@inject DashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<PageHeader
    Eyebrow="Bankaool FinCore 360"
    Title="Dashboard fintech"
    Description="Vista principal del portal bancario con resumen de cuenta, movimientos y accesos rápidos." />

<QuickActions />

<ModuleShell CssClass="metrics-grid">
    <MetricCard
        Label="Cliente"
        Value="@Account.CustomerName"
        Description="@Account.AccountNumber"
        IsMain="true" />

    <MetricCard
        Label="Saldo disponible"
        Value="@($"{Account.AvailableBalance:N2} {Account.Currency}")"
        Description="Cuenta principal" />

    <MetricCard
        Label="Transferencias pendientes"
        Value="@Account.PendingTransfers.ToString()"
        Description="Operaciones por revisar" />

    <MetricCard
        Label="Riesgo"
        Value="@Account.RiskLevel"
        Description="Nivel operativo actual" />
</ModuleShell>

<section class="movements-section">
    <div class="section-title">
        <span>Actividad reciente</span>
        <h2>Movimientos</h2>
    </div>

    <ModuleShell>
        @foreach (var movement in RecentMovements)
        {
            <MovementRow Movement="movement" />
        }
    </ModuleShell>
</section>

@code {
    private DashboardAccount Account { get; set; } = new();
    private List<RecentMovement> RecentMovements { get; set; } = new();

    protected override void OnInitialized()
    {
        Account = DashboardService.GetDashboardAccount();
        RecentMovements = DashboardService.GetRecentMovements();
    }
}
