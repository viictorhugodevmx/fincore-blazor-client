@page "/access-denied"
@using FincoreBlazorClient.Components.Shared

<PageTitle>Acceso denegado</PageTitle>

<section class="access-denied-shell">
    <article class="access-denied-card">
        <StatusBadge Text="Acceso denegado" CssClass="session-badge danger" />

        <h1>No tienes permisos para ver esta sección</h1>
        <p>Inicia sesión para acceder al área segura del portal bancario.</p>

        <div class="actions-row">
            <ActionLink Href="/login" Text="Ir al login" />

            <ActionLink
                Href="/"
                Text="Volver al dashboard"
                CssClass="primary-link" />
        </div>
    </article>
</section>
