@page "/accounts"
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@inject DashboardService DashboardService

<PageTitle>Cuentas</PageTitle>

<section class="page-heading">
    <span class="eyebrow dark">Productos bancarios</span>
    <h1>Cuentas</h1>
    <p>Consulta de cuentas simuladas usando componentes y routing Blazor.</p>
</section>

<section class="accounts-list">
    @foreach (var account in AccountList)
    {
        <article class="account-row">
            <div>
                <span class="account-status @account.Status.ToLower()">@account.Status</span>
                <h2>@account.Alias</h2>
                <p>@account.AccountNumber · @account.ProductType</p>
            </div>

            <strong>@account.Balance.ToString("N2") @account.Currency</strong>
        </article>
    }
</section>

@code {
    private List<BankAccount> AccountList { get; set; } = new();

    protected override void OnInitialized()
    {
        AccountList = DashboardService.GetAccounts();
    }
}
