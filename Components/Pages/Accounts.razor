@page "/accounts"
@using FincoreBlazorClient.Models
@using FincoreBlazorClient.Services
@using FincoreBlazorClient.Components.Shared
@inject DashboardService DashboardService

<PageTitle>Cuentas</PageTitle>

<PageHeader
    Eyebrow="Productos bancarios"
    Title="Cuentas"
    Description="Consulta de cuentas simuladas usando componentes y routing Blazor." />

<section class="accounts-list">
    @foreach (var account in AccountList)
    {
        <AccountCard Account="account" />
    }
</section>

@code {
    private List<BankAccount> AccountList { get; set; } = new();

    protected override void OnInitialized()
    {
        AccountList = DashboardService.GetAccounts();
    }
}
